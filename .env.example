# =============================================================================
# CloudMart Environment Variables
# =============================================================================
# Copy this file to .env and replace placeholder values with your own.
# Do NOT commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# GCP Configuration
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-east1
GCP_ZONE=us-east1-b

# -----------------------------------------------------------------------------
# Cloud SQL
# -----------------------------------------------------------------------------
CLOUD_SQL_PRIVATE_IP=10.x.x.x
DB_PASSWORD=your-database-password

# -----------------------------------------------------------------------------
# Product Service
# -----------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/productdb
SPRING_DATASOURCE_USERNAME=cloudmart
SPRING_DATASOURCE_PASSWORD=your-database-password

# -----------------------------------------------------------------------------
# Order Service
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://cloudmart:your-database-password@localhost:5433/orderdb
REDIS_URL=redis://redis:6379/0
PRODUCT_SERVICE_URL=http://product-service:8080

# -----------------------------------------------------------------------------
# Pub/Sub
# -----------------------------------------------------------------------------
PUBSUB_PROJECT_ID=your-gcp-project-id
PUBSUB_TOPIC_ORDER_EVENTS=order-events

# -----------------------------------------------------------------------------
# Observability (OpenTelemetry)
# -----------------------------------------------------------------------------
OTEL_SERVICE_NAME=service-name
OTEL_EXPORTER_OTLP_ENDPOINT=http://alloy-traces.monitoring:4317
OTEL_METRICS_EXPORTER=none
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Alerting
# -----------------------------------------------------------------------------
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# -----------------------------------------------------------------------------
# Artifact Registry
# -----------------------------------------------------------------------------
ARTIFACT_REGISTRY=us-east1-docker.pkg.dev/your-project/cloudmart-docker
